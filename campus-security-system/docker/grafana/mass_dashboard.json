{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.3.1" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"background:linear-gradient(90deg,#1a1a2e,#16213e,#0f3460);padding:16px 24px;border-radius:8px;display:flex;align-items:center;justify-content:space-between\"><div><span style=\"font-size:26px;font-weight:900;color:#e94560;letter-spacing:2px\">MASS</span><span style=\"font-size:14px;color:#a8b2c1;margin-left:12px\">Multi-Agent Security System — Smart Campus</span></div><div style=\"font-size:12px;color:#53d8fb\">🔴 LIVE MONITORING &nbsp;|&nbsp; 9 Agents Active &nbsp;|&nbsp; 3 Network Domains</div></div>"
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "🌡️ System Threat Level",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 3 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "LOW",      "color": "green"  } } },
            { "type": "value", "options": { "1": { "text": "MEDIUM",   "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "HIGH",     "color": "orange" } } },
            { "type": "value", "options": { "3": { "text": "CRITICAL", "color": "red"    } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 2 },
              { "color": "red",    "value": 3 }
            ]
          },
          "unit": "short",
          "fontSize": 32
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "mass_threat_level",
          "legendFormat": "Threat Level",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "🚨 Active CRITICAL Incidents",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "mass_incidents_total{severity=\"CRITICAL\"}",
          "legendFormat": "Critical",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "🤖 Agents Healthy",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 7 },
              { "color": "green",  "value": 9 }
            ]
          },
          "unit": "short",
          "max": 9,
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "mass_agents_healthy_total",
          "legendFormat": "Healthy",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "🧠 HQ Correlations Fired",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "mass_correlations_total",
          "legendFormat": "Correlations",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "⚡ SOAR Commands Issued",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue",  "value": 1 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "mass_soar_commands_total",
          "legendFormat": "Commands",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "⏳ Pending Approvals",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "mass_pending_approvals_total",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "📈 Panel 2 — Alert Rate Over Time (All Domains)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "IoT Alerts" },        "properties": [{ "id": "color", "value": { "fixedColor": "#53d8fb", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Physical Access Alerts" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f9a825", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Data Network Alerts" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e94560", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "HQ Correlations" },    "properties": [{ "id": "color", "value": { "fixedColor": "#ab47bc", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(mass_iot_alerts_total[5m])*60",           "legendFormat": "IoT Alerts",             "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(mass_pac_alerts_total[5m])*60",           "legendFormat": "Physical Access Alerts", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(mass_data_alerts_total[5m])*60",          "legendFormat": "Data Network Alerts",    "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(mass_correlations_total[5m])*60",         "legendFormat": "HQ Correlations",        "refId": "D" }
      ]
    },

    {
      "id": 9,
      "type": "piechart",
      "title": "🔵 Panel 3 — Incidents by Severity",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e94560", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "HIGH" },     "properties": [{ "id": "color", "value": { "fixedColor": "#f9a825", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "MEDIUM" },   "properties": [{ "id": "color", "value": { "fixedColor": "#53d8fb", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "LOW" },      "properties": [{ "id": "color", "value": { "fixedColor": "#4caf50", "mode": "fixed" } }] }
        ]
      },
      "options": { "pieType": "donut", "tooltip": { "mode": "single" }, "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_incidents_total{severity=\"CRITICAL\"}", "legendFormat": "CRITICAL", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_incidents_total{severity=\"HIGH\"}",     "legendFormat": "HIGH",     "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_incidents_total{severity=\"MEDIUM\"}",   "legendFormat": "MEDIUM",   "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_incidents_total{severity=\"LOW\"}",      "legendFormat": "LOW",      "refId": "D" }
      ]
    },

    {
      "id": 10,
      "type": "gauge",
      "title": "📡 Panel 4 — Agent Health by Layer",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 60 },
              { "color": "green",  "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_iot_agents_healthy/3*100",  "legendFormat": "IoT Layer (3 agents)",            "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_pac_agents_healthy/3*100",  "legendFormat": "Physical Access (3 agents)",      "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_data_agents_healthy/3*100", "legendFormat": "Data Network (3 agents)",         "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_hq_agents_healthy/4*100",   "legendFormat": "HQ Intelligence (4 agents)",      "refId": "D" }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "🔒 Panel 5 — MITRE ATT&CK Techniques Detected",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_mitre_detections_total{technique=\"T1046\"}", "legendFormat": "T1046 Port Scan",          "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_mitre_detections_total{technique=\"T1110\"}", "legendFormat": "T1110 Brute Force",        "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_mitre_detections_total{technique=\"T1486\"}", "legendFormat": "T1486 Ransomware",         "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_mitre_detections_total{technique=\"T1003\"}", "legendFormat": "T1003 Credential Dump",    "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_mitre_detections_total{technique=\"T1048\"}", "legendFormat": "T1048 Data Exfiltration",  "refId": "E" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_mitre_detections_total{technique=\"T1078\"}", "legendFormat": "T1078 Valid Accounts",     "refId": "F" }
      ]
    },

    {
      "id": 12,
      "type": "table",
      "title": "🧠 Panel 6 — Latest HQ Correlations",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "CRITICAL": { "color": "red",    "index": 0 } } },
                { "type": "value", "options": { "HIGH":     { "color": "orange", "index": 1 } } }
              ]},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } },
      "transformations": [{ "id": "organize", "options": { "renameByName": { "correlation_type": "Correlation Type", "severity": "Severity", "domains_involved": "Domains", "created_at": "Time" } } }],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_correlation_info", "legendFormat": "{{correlation_type}} | {{severity}} | {{domains}}", "refId": "A" }
      ]
    },

    {
      "id": 13,
      "type": "table",
      "title": "⚡ Panel 7 — SOAR Playbook Executions",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "running":   { "color": "blue",   "index": 0 } } },
                { "type": "value", "options": { "completed": { "color": "green",  "index": 1 } } }
              ]},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_playbook_executions_total", "legendFormat": "{{playbook}} — {{status}}", "refId": "A" }
      ]
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "🎓 Panel 8 — Learning Agent: Model Performance (F1 Score)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green",  "value": 0.9 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Behavioral Agent F1" }, "properties": [{ "id": "color", "value": { "fixedColor": "#53d8fb", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "NDR Agent F1" },        "properties": [{ "id": "color", "value": { "fixedColor": "#f9a825", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "EDR Agent F1" },        "properties": [{ "id": "color", "value": { "fixedColor": "#e94560", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_model_f1_score{model=\"behavioral_agent\"}", "legendFormat": "Behavioral Agent F1", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_model_f1_score{model=\"ndr_agent\"}",        "legendFormat": "NDR Agent F1",        "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "mass_model_f1_score{model=\"edr_agent\"}",        "legendFormat": "EDR Agent F1",        "refId": "C" }
      ]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["MASS", "security", "campus", "cyber-physical"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MASS — Campus Security System",
  "uid": "mass-campus-security-v1",
  "version": 1
}
